APP_NAME=LegacyLens API
APP_ENV=production
APP_DEBUG=false

OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=legacylens-openai-index
PINECONE_NAMESPACE=nshmp-main
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
ENFORCE_EMBEDDING_DIMENSION=true
EXTERNAL_CALL_RETRIES=3
EXTERNAL_CALL_BACKOFF_SECONDS=0.5
EMBEDDING_CACHE_SIZE=512
RETRIEVAL_CANDIDATE_MULTIPLIER=4
RETRIEVAL_MAX_CANDIDATES=40
RETRIEVAL_LEXICAL_WEIGHT=0.25
RETRIEVAL_MIN_HYBRID_SCORE=0.35
RETRIEVAL_FOCUS_TERM_GUARDRAIL_ENABLED=true
RETRIEVAL_FOCUS_TERM_ABSENT_CAP=0.20
RETRIEVAL_FOCUS_TERM_PARTIAL_COVERAGE_CAP=0.45
RAG_MAX_CONTEXT_CHUNKS=6
PINECONE_FALLBACK_NAMESPACE=
STARTUP_SMOKE_MODE=off
STARTUP_SMOKE_QUERY=startup health probe
STARTUP_SMOKE_TOP_K=1
