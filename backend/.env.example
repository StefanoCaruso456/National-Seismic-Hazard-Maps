APP_NAME=LegacyLens API
APP_ENV=production
APP_DEBUG=false

OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=legacylens-openai-index
PINECONE_NAMESPACE=nshmp-main
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
ENFORCE_EMBEDDING_DIMENSION=true
EXTERNAL_CALL_RETRIES=3
EXTERNAL_CALL_BACKOFF_SECONDS=0.5
EMBEDDING_CACHE_SIZE=512
RETRIEVAL_CANDIDATE_MULTIPLIER=4
RETRIEVAL_MAX_CANDIDATES=40
RETRIEVAL_LEXICAL_WEIGHT=0.25
RETRIEVAL_MIN_HYBRID_SCORE=0.35
RETRIEVAL_FOCUS_TERM_GUARDRAIL_ENABLED=true
RETRIEVAL_FOCUS_TERM_ABSENT_CAP=0.20
RETRIEVAL_FOCUS_TERM_PARTIAL_COVERAGE_CAP=0.45
RETRIEVAL_QUERY_CACHE_TTL_SECONDS=20
RETRIEVAL_QUERY_CACHE_MAX_ENTRIES=256
RETRIEVAL_IDENTIFIER_FILE_LIMIT=80
RETRIEVAL_IDENTIFIER_LEXICAL_ENABLED=true
RETRIEVAL_DETERMINISTIC_RERANK_ENABLED=true
RETRIEVAL_CONTEXT_EXPANSION_ENABLED=true
RETRIEVAL_CONTEXT_NEIGHBOR_LINES=6
RETRIEVAL_CONTEXT_PARENT_MAX_LINES=220
RETRIEVAL_CONTEXT_HEADER_LINES=18
HYBRID_TOP_K_DEFAULT=12
HYBRID_MAX_CANDIDATE_FILES=50
GITNEXUS_ENABLED=true
GITNEXUS_BASE_URL=http://127.0.0.1:4000
GITNEXUS_DEFAULT_REPO=
GITNEXUS_MCP_COMMAND=npx -y gitnexus@latest mcp
GITNEXUS_CALL_TIMEOUT_SECONDS=30
GITNEXUS_STARTUP_TIMEOUT_SECONDS=45
GITNEXUS_BOOTSTRAP_ENABLED=false
GITNEXUS_BOOTSTRAP_REPO_URL=https://github.com/StefanoCaruso456/National-Seismic-Hazard-Maps
GITNEXUS_BOOTSTRAP_REPO_PATH=/tmp/nshmp-main
GITNEXUS_BOOTSTRAP_REPO_REF=
GITNEXUS_ANALYZE_COMMAND=gitnexus analyze
GITNEXUS_ANALYZE_TIMEOUT_SECONDS=180
REPO_ROOT_OVERRIDE=
RAG_MAX_CONTEXT_CHUNKS=6
PINECONE_FALLBACK_NAMESPACE=
STARTUP_SMOKE_MODE=off
STARTUP_SMOKE_QUERY=startup health probe
STARTUP_SMOKE_TOP_K=1
